# ==========================================
# Configuración de la Aplicación (Branding)
# ==========================================
APP_NAME=MontarAI
APP_URL=https://montarai.com
APP_SUPPORT_EMAIL=soporte@montarai.com

# ==========================================
# Configuración de Email
# ==========================================
EMAIL_FROM_NAME=MontarAI
EMAIL_FROM_ADDRESS=noreply@montarai.com

# ==========================================
# Branding Visual (Opcional)
# ==========================================
APP_PRIMARY_COLOR=#007bff
APP_LOGO_URL=https://montarai.com/logo.png
APP_FAVICON_URL=https://montarai.com/favicon.ico

# ==========================================
# Datos de la Empresa (Opcional)
# ==========================================
COMPANY_NAME=MontarAI SL
COMPANY_ADDRESS=Calle Mayor 123, 28001 Madrid, España
COMPANY_PHONE=+34 912 345 678
COMPANY_CIF=B12345678

# ==========================================
# Redes Sociales (Dejar en blanco para ocultar)
# ==========================================
SOCIAL_FACEBOOK=https://facebook.com/montarai
SOCIAL_INSTAGRAM=https://instagram.com/montarai
SOCIAL_TWITTER=https://twitter.com/montarai
SOCIAL_LINKEDIN=https://linkedin.com/company/montarai
SOCIAL_YOUTUBE=
SOCIAL_TIKTOK=
SOCIAL_BLUESKY=

# ==========================================
# URLs Legales (Opcional)
# ==========================================
URL_TERMS=https://montarai.com/terminos
URL_PRIVACY=https://montarai.com/privacidad
URL_LEGAL=https://montarai.com/aviso-legal
URL_COOKIES=https://montarai.com/cookies
URL_CONTACT=https://montarai.com/contacto

# ==========================================
# Configuración del Servidor
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Base de datos MySQL
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=montarai_backend

# ==========================================
# JWT
# ==========================================
JWT_SECRET=tu_secreto_super_seguro_cambia_esto
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=refresh_secreto_diferente_y_seguro_para_tokens_refresh_12345

# ==========================================
# SMTP (Email)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_app_aqui

# ==========================================
# Stripe
# ==========================================
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_aqui
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui
STRIPE_WEBHOOK_SECRET=whsec_tu_secreto_webhook_aqui

# ==========================================
# Limpieza de Usuarios No Verificados
# ==========================================
CLEANUP_UNVERIFIED_ENABLED=true
CLEANUP_UNVERIFIED_HOURS=48
